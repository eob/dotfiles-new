#!/usr/bin/env bash
# devbox-fwd — forward-only SSH tunnel to the devbox, to run *alongside* `devbox`.
#
# mosh (what `devbox` uses) has no port forwarding — it's a fundamental mosh
# limitation, not a config gap. So when you're in over mosh, hitting
# localhost:3000 on this machine reaches nothing. Run `devbox-fwd` in a second
# terminal to carry the dev-server ports over a plain SSH tunnel while mosh
# keeps driving your shell. No remote shell is opened (-N); it just forwards.
#
# Reaps the same stale-forwarder failure devbox-ssh handles:
#   bind [127.0.0.1]:5173: Address already in use
#   channel_setup_fwd_listener_tcpip: cannot listen to port: 5173
# A previous tunnel whose network dropped (sleep / wifi change) can keep holding
# these local ports; we kill only our own stale ssh forwarders before binding,
# then connect with ExitOnForwardFailure so a genuinely-blocked port fails loudly.
#
# Connection details come from ~/.zshrc.local (kept out of the repo):
#   DEVBOX_IP        required — devbox public IP/host
#   DEVBOX_USERNAME  required — ssh username
#   DEVBOX_PORT      optional — SSH TCP port (default 443)
#   DEVBOX_SSH_KEY   optional — identity file for ssh
#
# Usage:
#   devbox-fwd        # forward dev ports, stay attached until Ctrl-C
set -euo pipefail

: "${DEVBOX_IP:?set DEVBOX_IP in ~/.zshrc.local}"
: "${DEVBOX_USERNAME:?set DEVBOX_USERNAME in ~/.zshrc.local}"
port="${DEVBOX_PORT:-443}"

# Local<->remote forwards (thisMachine:PORT -> devbox:PORT).
# NOTE: the kayad daemon ports (5292/5293) are deliberately NOT forwarded — kaya
# must run against a LOCAL daemon on this machine. Tunneling them makes `kaya`
# reach the devbox's daemon, which can't see your local files ("File not found").
PORTS=(8080 5173 3000 8000 6006)

# PIDs LISTENing on a given local TCP port (lsof preferred, fuser fallback).
port_listeners() {
  if command -v lsof >/dev/null 2>&1; then
    lsof -ti "tcp:${1}" -sTCP:LISTEN 2>/dev/null || true
  else
    fuser "${1}/tcp" 2>/dev/null || true
  fi
}

# True only for an ssh process — so we never kill a real local server that
# happens to sit on a forwarded port; only our own stale tunnels.
is_ssh() { [[ "$(ps -p "$1" -o comm= 2>/dev/null)" == *ssh ]]; }

# Reap stale forwarders still holding our local ports.
reap_stale_forwards() {
  local p pid killed=0
  for p in "${PORTS[@]}"; do
    for pid in $(port_listeners "$p"); do
      if is_ssh "$pid"; then kill "$pid" 2>/dev/null && killed=1; fi
    done
  done
  (( killed )) || return 0
  sleep 0.3  # let the sockets actually release before we rebind
  for p in "${PORTS[@]}"; do
    for pid in $(port_listeners "$p"); do
      is_ssh "$pid" && kill -9 "$pid" 2>/dev/null || true
    done
  done
}

reap_stale_forwards

forwards=()
for p in "${PORTS[@]}"; do
  forwards+=(-L "${p}:localhost:${p}")
done

ssh_opts=(
  -N                              # no remote shell — forward only
  -p "${port}"
  -o ServerAliveInterval=20
  -o ServerAliveCountMax=3
  -o TCPKeepAlive=yes
  -o ExitOnForwardFailure=yes
)
[[ -n "${DEVBOX_SSH_KEY:-}" ]] && ssh_opts+=(-i "${DEVBOX_SSH_KEY}")

echo "devbox-fwd: forwarding ${PORTS[*]} — Ctrl-C to stop" >&2
exec ssh "${ssh_opts[@]}" "${forwards[@]}" "${DEVBOX_USERNAME}@${DEVBOX_IP}"
