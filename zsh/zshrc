# zshrc — cross-platform, runtime-detected
# Managed by kern/dotfiles

_OS="$(uname)"

# env
export EDITOR=nvim
export VISUAL="$EDITOR"
export PATH="${HOME}/.dotfiles/bin:${HOME}/.local/bin:${PATH}"

# TERM fallback: if this host has no terminfo entry for the advertised $TERM
# (e.g. connecting from a terminal whose terminfo was never installed here),
# fall back to xterm-256color so colors/keys don't break. Harmless when the
# entry exists.
if [[ -n "$TERM" && "$TERM" != "xterm-256color" ]] && command -v infocmp &>/dev/null; then
  if ! infocmp "$TERM" &>/dev/null; then
    export TERM=xterm-256color
  fi
fi

# brew (macOS)
if [[ "$_OS" == "Darwin" && -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# zsh plugins
if [[ "$_OS" == "Linux" ]]; then
  [[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] \
    && source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  [[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] \
    && source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
elif [[ "$_OS" == "Darwin" ]]; then
  if [[ -f /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  elif [[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  fi
  if [[ -f /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh
  elif [[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
  fi
fi

# base16
BASE16_SHELL="${HOME}/.config/base16-shell/"
[[ -n "$PS1" ]] && [[ -s "$BASE16_SHELL/profile_helper.sh" ]] && eval "$("$BASE16_SHELL/profile_helper.sh")"

# Tokyo Night Dark — vendored base16 scheme (upstream base16-shell ships none).
# Sourced last so it overrides any persisted ~/.base16_theme.
[[ -n "$PS1" ]] && [[ -s "${HOME}/.dotfiles/zsh/base16-tokyo-night-dark.sh" ]] \
  && source "${HOME}/.dotfiles/zsh/base16-tokyo-night-dark.sh"

# git prompt
autoload -U add-zsh-hook
source "${HOME}/.dotfiles/zsh/git-prompt.zsh"
source "${HOME}/.dotfiles/zsh/multiline-prompt.zsh"

# completions
autoload -U compinit && compinit
autoload -U bashcompinit && bashcompinit

# aliases
alias vim=nvim
function v() { nvim ${1:-.}; }
alias gs='git status -sb'
alias gcob='git checkout -b'
alias gco='git checkout'
alias gc='git commit -av'
alias gb='git branch'
alias gp='git push origin $(git branch --show-current)'
alias gpf='git push --force origin $(git branch --show-current)'
alias c='claude --dangerously-skip-permissions'
alias editzsh='nvim ~/.zshrc'
alias sourcezsh='source ~/.zshrc'
alias vdot="cd ${HOME}/.dotfiles && v"
# devbox — mosh to the devbox over 443 with a 24h server network timeout
alias devbox='MOSH_SERVER_NETWORK_TMOUT=86400 mosh -p 443 devbox'
# serve [PATH] — free port 8000, then serve PATH (default ".")
serve() {
  local port=8000
  if fuser "$port/tcp" &>/dev/null; then
    echo "serve: freeing port $port"
    fuser -k -TERM "$port/tcp" &>/dev/null
    sleep 0.3
    fuser -k -KILL "$port/tcp" &>/dev/null  # force-kill anything that ignored TERM
  fi
  miniserve --port $port "${1:-.}"
}
alias z='zellij-launch'   # attach to (or create) the default zellij session

# l -> eza/exa or ls
if command -v eza &>/dev/null; then
  alias l='eza'
elif command -v exa &>/dev/null; then
  alias l='exa'
else
  alias l='ls --color=auto'
fi

# fzf & ripgrep
if command -v rg &>/dev/null; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden --smart-case --follow --glob "!.git/*"'
fi
[[ -f "${HOME}/.fzf.zsh" ]] && source "${HOME}/.fzf.zsh"

# zoxide (cd replacement)
if command -v zoxide &>/dev/null; then
  if [[ -o interactive ]]; then
    eval "$(zoxide init zsh --cmd cd)"
  else
    eval "$(zoxide init zsh)"
  fi
fi

# delta (git pager)
if command -v delta &>/dev/null; then
  export GIT_PAGER=delta
fi

# Force emacs keybindings. zsh otherwise auto-selects vi mode because
# $EDITOR=nvim matches *vi*, which leaves the Mac delete key bound to
# `vi-backward-char` in vicmd mode (cursor moves instead of deleting).
bindkey -e

# history (up/down arrow prefix search)
autoload -U history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end
bindkey "^[[A" history-beginning-search-backward-end
bindkey "^[[B" history-beginning-search-forward-end

# history settings
HISTSIZE=50000
SAVEHIST=50000
HISTFILE="${HOME}/.zsh_history"
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# allow # comments on the interactive command line
setopt interactive_comments

# fastrebase
function fastrebase() {
  git fetch origin
  UPSTREAM_BRANCH="${1:-origin/master}"
  MERGE_BASE=$(git merge-base "$UPSTREAM_BRANCH" HEAD)
  if [[ -n "$(git status -s)" ]]; then
    if read -q "choice?You have unstaged changes. Stash them? [yn] "; then
      git add .
      git stash
    else
      return
    fi
  fi
  git branch kern/backups/$(date +%s)
  git reset --soft "$MERGE_BASE"
  git commit -n --edit -m"$(git log --format=%B --reverse HEAD..HEAD@{1})"
  git rebase "$UPSTREAM_BRANCH"
}

# irebase
function irebase() {
  git fetch origin
  UPSTREAM_BRANCH="${1:-origin/master}"
  MERGE_BASE=$(git merge-base "$UPSTREAM_BRANCH" HEAD)
  if [[ -n "$(git status -s)" ]]; then
    if read -q "choice?You have unstaged changes. Stash them? [yn] "; then
      git add .
      git stash
    else
      return
    fi
  fi
  git branch kern/backups/$(date +%s)
  git rebase -i "$UPSTREAM_BRANCH"
}

# cargo/rust
[[ -f "${HOME}/.cargo/env" ]] && source "${HOME}/.cargo/env"

# go
if command -v go &>/dev/null; then
  export GOPATH="${HOME}/go"
  export GOBIN="${GOPATH}/bin"
  export PATH="${GOBIN}:${PATH}"
fi

# volta
if [[ -d "${HOME}/.volta" ]]; then
  export VOLTA_HOME="${HOME}/.volta"
  export PATH="${VOLTA_HOME}/bin:${PATH}"
fi

# kubectl
if command -v kubectl &>/dev/null; then
  source <(kubectl completion zsh)
fi

# mcfly
if command -v mcfly &>/dev/null; then
  eval "$(mcfly init zsh)"
fi

# python3 (macOS homebrew)
if [[ "$_OS" == "Darwin" && -d "/opt/homebrew/opt/python/libexec/bin" ]]; then
  export PATH="/opt/homebrew/opt/python/libexec/bin:${PATH}"
fi

# local overrides
[[ -f "${HOME}/.zshrc.local" ]] && source "${HOME}/.zshrc.local"

# bun completions
[ -s "/home/ted/.bun/_bun" ] && source "/home/ted/.bun/_bun"


# Added by Antigravity CLI installer
export PATH="/home/ted/.local/bin:$PATH"

# Auto-start zellij when connecting via mosh: attach to (or create) the default
# session. Detects mosh by walking the process tree for mosh-server. Skips if
# already inside zellij ($ZELLIJ), non-interactive, or zellij isn't installed.
if [[ -o interactive && -z "${ZELLIJ:-}" ]] && command -v zellij &>/dev/null; then
  _ppid=$PPID
  while [[ -n "$_ppid" && "$_ppid" -gt 1 ]]; do
    if [[ "$(ps -o comm= -p "$_ppid" 2>/dev/null)" == *mosh-server* ]]; then
      exec zellij-launch
    fi
    _ppid=$(ps -o ppid= -p "$_ppid" 2>/dev/null | tr -d ' ')
  done
  unset _ppid
fi
